NODE_ENV=development

# Multi-tenant defaults (SaaS-ready, single-tenant runtime for now)
DEFAULT_TENANT_ID=GOIUUDAI
TENANT_HEADER_KEY=x-tenant-id
TENANCY_MODE=single

# Auth
AUTH_ENABLED=false
NEXT_PUBLIC_AUTH_ENABLED=false
JWT_SECRET=REPLACE_ME_WITH_SECURE_JWT_SECRET
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
JWT_DEFAULT_TENANT_CLAIM=GOIUUDAI
PERMISSION_ENGINE_ENABLED=false

# Database + cache
DATABASE_URL=postgresql://erp:REPLACE_WITH_SECURE_PASSWORD@localhost:55432/erp_retail
# Use only for tests/dev smoke to skip Prisma startup connection.
# PRISMA_SKIP_CONNECT=false
REDIS_URL=redis://localhost:6379

# Services
API_PORT=3001
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# AI scoring (OpenAI-compatible, e.g. 9router)
AI_OPENAI_COMPAT_BASE_URL=
AI_OPENAI_COMPAT_API_KEY=
AI_OPENAI_COMPAT_MODEL=gpt-4o-mini
AI_OPENAI_COMPAT_TIMEOUT_MS=45000

# Zalo OA webhook verification (optional but recommended)
ZALO_OA_WEBHOOK_SECRET=

# Zalo OA outbound (optional, dùng khi gửi OA qua official API)
ZALO_OA_OUTBOUND_URL=
ZALO_OA_ACCESS_TOKEN=
ZALO_OA_API_BASE_URL=https://openapi.zalo.me/v3.0/oa
ZALO_OA_OUTBOUND_TIMEOUT_MS=20000

# Search engine (Level 2: hybrid Meilisearch + PostgreSQL fallback)
SEARCH_ENGINE=sql
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=
MEILI_INDEX_PREFIX=erp
MEILI_TIMEOUT_MS=45000
MEILI_ENABLE_WRITE_SYNC=false
MEILI_PORT=7700

# Audit archive hot/cold tiers (MinIO on VM)
AUDIT_ARCHIVE_S3_ENDPOINT=http://localhost:9000
AUDIT_ARCHIVE_S3_BUCKET=erp-audit-archive
AUDIT_ARCHIVE_S3_REGION=us-east-1
AUDIT_ARCHIVE_S3_ACCESS_KEY=erpminio
AUDIT_ARCHIVE_S3_SECRET_KEY=REPLACE_WITH_SECURE_MINIO_PASSWORD
AUDIT_ARCHIVE_S3_FORCE_PATH_STYLE=true
AUDIT_ARCHIVE_S3_TLS_ENABLED=false
AUDIT_MAINTENANCE_SCHEDULER_ENABLED=true
# 19 UTC = 02:00 ICT (off-peak)
AUDIT_MAINTENANCE_SCHEDULER_UTC_HOUR=19
# Cold query window guard per request
AUDIT_COLD_QUERY_MAX_DAYS=31

# MinIO local ports/credentials (docker-compose)
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=erpminio
MINIO_ROOT_PASSWORD=REPLACE_WITH_SECURE_MINIO_PASSWORD
