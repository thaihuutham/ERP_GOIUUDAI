NODE_ENV=development

# Multi-tenant defaults (SaaS-ready, single-tenant runtime for now)
DEFAULT_TENANT_ID=tenant_demo_company
TENANT_HEADER_KEY=x-tenant-id

# Auth
AUTH_ENABLED=false
JWT_SECRET=change_me_to_a_long_secret
JWT_DEFAULT_TENANT_CLAIM=tenant_demo_company

# Database + cache
DATABASE_URL=postgresql://erp:erp@localhost:55432/erp_retail
# Use only for tests/dev smoke to skip Prisma startup connection.
# PRISMA_SKIP_CONNECT=false
REDIS_URL=redis://localhost:6379

# Services
API_PORT=3001
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# AI scoring (OpenAI-compatible, e.g. 9router)
AI_OPENAI_COMPAT_BASE_URL=
AI_OPENAI_COMPAT_API_KEY=
AI_OPENAI_COMPAT_MODEL=gpt-4o-mini
AI_OPENAI_COMPAT_TIMEOUT_MS=45000

# Zalo OA webhook verification (optional but recommended)
ZALO_OA_WEBHOOK_SECRET=

# Zalo OA outbound (optional, dùng khi gửi OA qua official API)
ZALO_OA_OUTBOUND_URL=
ZALO_OA_ACCESS_TOKEN=
ZALO_OA_API_BASE_URL=https://openapi.zalo.me/v3.0/oa
ZALO_OA_OUTBOUND_TIMEOUT_MS=20000
