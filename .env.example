## Root example for local development.
## Full key list is available in config/.env.example.

NODE_ENV=development
DEFAULT_TENANT_ID=GOIUUDAI
TENANCY_MODE=single
TENANT_HEADER_KEY=x-tenant-id

# Secure-by-default auth posture.
AUTH_ENABLED=true
DEV_AUTH_BYPASS_ENABLED=false
NEXT_PUBLIC_AUTH_ENABLED=true
NEXT_PUBLIC_DEV_AUTH_BYPASS_ENABLED=false
JWT_SECRET=REPLACE_ME_WITH_SECURE_JWT_SECRET
PERMISSION_ENGINE_ENABLED=true
IAM_V2_ENABLED=

DATABASE_URL=postgresql://erp:REPLACE_WITH_SECURE_PASSWORD@localhost:55432/erp_retail
REDIS_URL=redis://localhost:6379

API_PORT=3001
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
