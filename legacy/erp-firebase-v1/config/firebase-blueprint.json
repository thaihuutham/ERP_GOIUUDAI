            }
          }
        },
        "status": { "type": "string", "enum": ["draft", "posted"] },
        "companyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "items", "status", "companyId"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A bill or invoice for AR/AP.",
