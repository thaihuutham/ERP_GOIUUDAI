    },
    "WorkflowDefinition": {
      "title": "WorkflowDefinition",
      "description": "Defines a sequence of steps for a specific business process.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "targetEntity": { "type": "string", "description": "e.g., PurchaseOrder, Invoice, LeaveRequest" },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "order": { "type": "number" },
              "label": { "type": "string" },
              "approverRole": { "type": "string", "enum": ["admin", "manager", "staff"] },
              "condition": { "type": "string", "description": "Optional logic or threshold" }
            }
          }
        },
        "isActive": { "type": "boolean" },
        "companyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "targetEntity", "steps", "isActive", "companyId"]
    },
    "WorkflowInstance": {
      "title": "WorkflowInstance",
