{
  "entities": {
    "Customer": {
      "title": "Customer",
      "description": "Represents a retail customer for digital products and services.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the customer." },
        "name": { "type": "string", "description": "Full name of the customer." },
        "email": { "type": "string", "format": "email", "description": "Email address of the customer." },
        "phone": { "type": "string", "description": "Phone number of the customer." },
        "status": { "type": "string", "enum": ["active", "inactive", "blocked"], "description": "Current status of the customer account." },
        "totalSpent": { "type": "number", "description": "Total amount spent by the customer." },
        "lastOrderDate": { "type": "string", "format": "date-time", "description": "Timestamp of the last order." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the customer was added to the system." },
        "companyId": { "type": "string" },
        "branchId": { "type": "string" },
        "departmentId": { "type": "string" },
        "teamId": { "type": "string" },
        "employeeId": { "type": "string" }
      },
      "required": ["name", "email", "status", "companyId", "branchId", "departmentId", "teamId", "employeeId"]
    },
    "Product": {
      "title": "Product",
      "description": "Represents a digital product or service offered by the business.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the product." },
        "name": { "type": "string", "description": "Name of the product or service." },
        "type": { "type": "string", "enum": ["digital_product", "service"], "description": "Category of the item." },
        "price": { "type": "number", "description": "Unit price of the product." },
        "description": { "type": "string", "description": "Detailed description of the product." },
        "status": { "type": "string", "enum": ["available", "discontinued"], "description": "Availability status." },
        "companyId": { "type": "string" }
      },
      "required": ["name", "type", "price", "status", "companyId"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a sales transaction.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the order." },
        "customerId": { "type": "string", "description": "Reference to the customer who placed the order." },
        "customerName": { "type": "string", "description": "Denormalized customer name for easier display." },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "productName": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number", "description": "Total price of the order." },
        "status": { "type": "string", "enum": ["completed", "pending", "cancelled", "pending_approval"], "description": "Current status of the order." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the order was created." },
        "companyId": { "type": "string" },
        "branchId": { "type": "string" },
        "departmentId": { "type": "string" },
        "teamId": { "type": "string" },
        "employeeId": { "type": "string" }
      },
      "required": ["customerId", "items", "totalAmount", "status", "createdAt", "companyId", "branchId", "departmentId", "teamId", "employeeId"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Represents an internal staff member.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier (UID) for the employee." },
        "name": { "type": "string", "description": "Full name of the employee." },
        "email": { "type": "string", "format": "email", "description": "Work email address." },
        "role": { "type": "string", "enum": ["admin", "manager", "staff"], "description": "Access level within the ERP." },
        "roleLevel": { "type": "number", "description": "1: Company Admin, 2: Branch Manager, 3: Dept Manager, 4: Team Leader, 5: Employee" },
        "companyId": { "type": "string" },
        "branchId": { "type": "string" },
        "departmentId": { "type": "string" },
        "teamId": { "type": "string" },
        "baseSalary": { "type": "number", "description": "Base monthly salary." },
        "joinDate": { "type": "string", "format": "date", "description": "Date the employee joined the company." },
        "leaveBalance": { "type": "number", "description": "Remaining annual leave days." },
        "status": { "type": "string", "enum": ["active", "on_leave", "terminated"], "description": "Current employment status." }
      },
      "required": ["name", "email", "role", "roleLevel", "companyId", "branchId", "departmentId", "teamId"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Tracks employee daily attendance.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "checkIn": { "type": "string", "format": "date-time" },
        "checkOut": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["present", "late", "absent", "on_leave"] },
        "companyId": { "type": "string" },
        "branchId": { "type": "string" },
        "departmentId": { "type": "string" }
      },
      "required": ["employeeId", "date", "status", "companyId"]
    },
    "LeaveRequest": {
      "title": "LeaveRequest",
      "description": "Employee requests for time off.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "type": { "type": "string", "enum": ["annual", "sick", "unpaid", "other"] },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "approvedBy": { "type": "string" },
        "companyId": { "type": "string" },
        "branchId": { "type": "string" },
        "departmentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["employeeId", "type", "startDate", "endDate", "status", "companyId"]
    },
    "Payroll": {
      "title": "Payroll",
      "description": "Monthly payroll record for an employee.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "month": { "type": "integer" },
        "year": { "type": "integer" },
        "baseSalary": { "type": "number" },
        "allowances": { "type": "number" },
        "deductions": { "type": "number" },
        "netSalary": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "paid"] },
        "paidAt": { "type": "string", "format": "date-time" },
        "companyId": { "type": "string" },
        "branchId": { "type": "string" },
        "departmentId": { "type": "string" }
      },
      "required": ["employeeId", "month", "year", "baseSalary", "netSalary", "status", "companyId"]
    },
    "SystemStats": {
      "title": "SystemStats",
      "description": "Global system statistics",
      "type": "object",
      "properties": {
        "totalRevenue": { "type": "number" },
        "totalCustomers": { "type": "integer" },
        "totalOrders": { "type": "integer" },
        "totalProducts": { "type": "integer" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "Asset": {
      "title": "Asset",
      "description": "Represents a physical or digital asset owned by the company.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "category": { "type": "string", "enum": ["computer", "furniture", "vehicle", "other"] },
        "purchaseDate": { "type": "string", "format": "date-time" },
        "purchasePrice": { "type": "number" },
        "status": { "type": "string", "enum": ["available", "in_use", "maintenance", "retired"] },
        "depreciationMethod": { "type": "string", "enum": ["linear", "declining_balance", "none"] },
        "usefulLife": { "type": "number", "description": "Useful life in months." },
        "salvageValue": { "type": "number" },
        "accumulatedDepreciation": { "type": "number" },
        "companyId": { "type": "string" },
        "branchId": { "type": "string" },
        "departmentId": { "type": "string" },
        "currentAssigneeId": { "type": "string" },
        "currentAssigneeType": { "type": "string", "enum": ["employee", "department", "branch", ""] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "code", "category", "status", "companyId"]
    },
    "AssetAllocation": {
      "title": "AssetAllocation",
      "description": "Tracks the assignment of an asset to an entity.",
