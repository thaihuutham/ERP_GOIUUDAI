        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "estimatedHours": { "type": "number" },
        "actualHours": { "type": "number" },
        "companyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "name", "status", "companyId"]
    },
