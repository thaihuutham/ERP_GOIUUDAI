        "allocatedDate": { "type": "string", "format": "date-time" },
        "returnedDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "returned"] },
        "notes": { "type": "string" },
        "allocatedBy": { "type": "string" },
        "companyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["assetId", "assigneeId", "assigneeType", "status", "allocatedBy", "companyId"]
    },
    "Vendor": {
      "title": "Vendor",
