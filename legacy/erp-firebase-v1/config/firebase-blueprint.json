        "type": { "type": "string", "enum": ["asset", "liability", "equity", "revenue", "expense"] },
        "balance": { "type": "number" },
        "companyId": { "type": "string" }
      },
      "required": ["code", "name", "type", "companyId"]
    },
    "JournalEntry": {
      "title": "JournalEntry",
      "description": "A manual or automatic accounting entry.",
      "type": "object",
      "properties": {
