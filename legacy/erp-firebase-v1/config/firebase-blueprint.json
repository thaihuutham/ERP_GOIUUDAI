      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["receivable", "payable"] },
        "partnerId": { "type": "string", "description": "Reference to Customer or Vendor." },
        "partnerName": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "amount": { "type": "number" },
        "taxAmount": { "type": "number" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["unpaid", "partially_paid", "paid", "overdue"] },
        "companyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "partnerId", "amount", "totalAmount", "status", "companyId"]
    },
    "BudgetPlan": {
      "title": "BudgetPlan",
