generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum PermissionAction {
  VIEW
  CREATE
  UPDATE
  DELETE
  APPROVE
}

enum PermissionEffect {
  ALLOW
  DENY
}

enum IamSubjectType {
  USER
  POSITION
  TEMPLATE
}

enum IamScopeMode {
  SELF
  SUBTREE
  UNIT_FULL
}

enum IamGrantReason {
  WORKFLOW_ASSIGNMENT
  MANUAL_OVERRIDE
  SYSTEM_SYNC
}

enum OrgUnitType {
  COMPANY
  BRANCH
  DEPARTMENT
  TEAM
}

enum GenericStatus {
  ACTIVE
  INACTIVE
  DRAFT
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

enum CheckoutOrderGroup {
  INSURANCE
  TELECOM
  DIGITAL
}

enum CheckoutOrderStatus {
  PENDING_PAYMENT
  PARTIALLY_PAID
  PAID
  ACTIVATING
  ACTIVE
  CANCELLED
}

enum CheckoutLineActivationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum PaymentIntentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum PaymentTransactionStatus {
  RECEIVED
  APPLIED
  DUPLICATE
  REJECTED
}

enum CustomerCareStatus {
  MOI_CHUA_TU_VAN
  DANG_SUY_NGHI
  DONG_Y_CHUYEN_THANH_KH
  KH_TU_CHOI
  KH_DA_MUA_BEN_KHAC
  NGUOI_NHA_LAM_THUE_BAO
  KHONG_NGHE_MAY_LAN_1
  KHONG_NGHE_MAY_LAN_2
  SAI_SO_KHONG_TON_TAI_BO_QUA_XOA
}

enum CustomerZaloNickType {
  CHUA_KIEM_TRA
  CHUA_CO_NICK_ZALO
  CHAN_NGUOI_LA
  GUI_DUOC_TIN_NHAN
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum AttendanceMethod {
  REMOTE_TRACKED
  OFFICE_EXCEL
  EXEMPT
}

enum HrGoalTrackingMode {
  MANUAL
  AUTO
  HYBRID
}

enum HrAppendixCode {
  PL01
  PL02
  PL03
  PL04
  PL05
  PL06
  PL10
}

enum HrAppendixSubmissionStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum HrAppendixEvidenceType {
  LINK
  FILE
}

enum HrAppendixRevisionStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum HrDailyScoreStatus {
  PROVISIONAL
  FINAL
}

enum HrPipCaseStatus {
  DRAFT
  OPEN
  CLOSED
}

enum PayrollComponentType {
  EARNING
  DEDUCTION
}

enum PayrollFormulaType {
  FIXED
  PERCENT_BASE
}

enum ConversationChannel {
  ZALO_PERSONAL
  ZALO_OA
  FACEBOOK
  OTHER
}

enum ZaloAccountPermissionLevel {
  READ
  CHAT
  ADMIN
}

enum ZaloCampaignStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELED
}

enum ZaloCampaignSelectionPolicy {
  PRIORITIZE_RECENT_INTERACTION
  AVOID_PREVIOUSLY_INTERACTED_ACCOUNT
}

enum ZaloCampaignAccountStatus {
  READY
  PAUSED_ERROR
  DONE
  DISABLED
}

enum ZaloCampaignRecipientStatus {
  PENDING
  IN_PROGRESS
  SENT
  SKIPPED
  FAILED
}

enum ZaloCampaignAttemptStatus {
  SENT
  FAILED
  SKIPPED
}

enum ConversationSenderType {
  AGENT
  CUSTOMER
  SYSTEM
}

enum ConversationMessageOrigin {
  EXTERNAL
  USER
  CAMPAIGN
  AI
  SYSTEM
}

enum ConversationEvaluationVerdict {
  PASS
  FAIL
  SKIP
  ERROR
}

enum AuditOperationType {
  READ
  WRITE
}

enum AuditArchiveStatus {
  PENDING
  COMPLETED
  FAILED
  NOOP
}

enum RecruitmentStage {
  APPLIED
  SCREENING
  INTERVIEW
  ASSESSMENT
  OFFER
  HIRED
}

enum RecruitmentApplicationStatus {
  ACTIVE
  REJECTED
  WITHDRAWN
  HIRED
}

enum RecruitmentSource {
  REFERRAL
  JOB_BOARD
  SOCIAL_MEDIA
  CAREER_SITE
  AGENCY
  CAMPUS
  OTHER
}

enum RecruitmentInterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum RecruitmentOfferStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ACCEPTED
  DECLINED
  CANCELED
}

enum CustomFieldEntityType {
  CUSTOMER
  PRODUCT
  EMPLOYEE
  SALES_ORDER
  PURCHASE_ORDER
  INVOICE
  PROJECT
  HR_EVENT
  WORKFLOW_DEFINITION
  SERVICE_CONTRACT
  VEHICLE
  INSURANCE_POLICY
}

enum ServiceContractProductType {
  TELECOM_PACKAGE
  AUTO_INSURANCE
  MOTO_INSURANCE
  DIGITAL_SERVICE
}

enum ServiceContractStatus {
  ACTIVE
  EXPIRED
  CANCELED
}

enum ServiceContractSourceType {
  MANUAL
  SALES_ORDER
  EXTERNAL_SYNC
  EXCEL_BASELINE
  OCR_APPROVED
}

enum ContractRenewalReminderStatus {
  PENDING
  COMPLETED
  CANCELED
}

enum CustomerSocialPlatform {
  ZALO
  FACEBOOK
  TIKTOK
}

enum TelecomBeneficiaryType {
  SELF
  RELATIVE
}

enum VehicleKind {
  AUTO
  MOTO
}

enum InboundPolicyDocumentSourceType {
  API_SYNC
  MANUAL_UPLOAD
  EXTERNAL_LINK
}

enum InboundPolicyExtractionStatus {
  PENDING
  EXTRACTED
  FAILED
}

enum InboundPolicyReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CustomFieldType {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  DATETIME
  BOOLEAN
  SELECT
  MULTISELECT
  RELATION
  FORMULA
}

enum CustomFieldLifecycleStatus {
  DRAFT
  ACTIVE
  RETIRED
  ARCHIVED
}

enum CustomFieldWidgetChartType {
  KPI
  TABLE
  BAR
  LINE
  PIE
}

enum AiConversationJobStatus {
  QUEUED
  DISPATCHING
  DISPATCHED
  CALLBACK_RECEIVED
  REPLIED
  RETRIED
  FAILED
  HANDOFF
  SKIPPED_TAKEOVER
  SKIPPED_DISABLED
}

enum AiConversationOutboxStatus {
  PENDING
  SENT
  FAILED
  DEAD
}

model Tenant {
  id         String   @id @default(cuid())
  tenant_Id  String   @unique
  code       String   @unique
  name       String
  status     GenericStatus @default(ACTIVE)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenant_Id])
}

model User {
  id           String   @id @default(cuid())
  tenant_Id    String
  email        String
  passwordHash String?
  role         UserRole @default(USER)
  employeeId   String?
  isActive     Boolean  @default(true)
  mustChangePassword Boolean @default(false)
  failedLoginAttempts Int @default(0)
  lockedUntil DateTime?
  mfaEnabled Boolean @default(false)
  mfaSecretEnc String?
  mfaEnrolledAt DateTime?
  lastLoginAt  DateTime?
  passwordChangedAt DateTime?
  passwordResetAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenant_Id, email])
  @@index([tenant_Id])
  @@index([tenant_Id, employeeId])
}

model UserPositionAssignment {
  id           String        @id @default(cuid())
  tenant_Id    String
  userId       String
  positionId   String
  isPrimary    Boolean       @default(false)
  status       GenericStatus @default(ACTIVE)
  effectiveFrom DateTime?
  effectiveTo  DateTime?
  note         String?
  createdBy    String?
  updatedBy    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([tenant_Id, userId, positionId])
  @@index([tenant_Id])
  @@index([tenant_Id, userId, status])
  @@index([tenant_Id, positionId, status])
}

model Employee {
  id           String   @id @default(cuid())
  tenant_Id    String
  code         String?
  fullName     String
  email        String?
  phone        String?
  dateOfBirth  DateTime?
  gender       String?
  nationalId   String?
  address      String?
  bankAccountNo String?
  bankName     String?
  taxCode      String?
  department   String?
  departmentId String?
  orgUnitId    String?
  position     String?
  positionId   String?
  managerId    String?
  workShiftId  String?
  joinDate     DateTime?
  employmentType EmploymentType @default(FULL_TIME)
  attendanceMethod AttendanceMethod @default(REMOTE_TRACKED)
  customFieldSchemaVersion Int?
  baseSalary   Decimal? @db.Decimal(18, 2)
  status       GenericStatus @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenant_Id, code])
  @@index([tenant_Id])
  @@index([tenant_Id, orgUnitId])
  @@index([tenant_Id, departmentId])
  @@index([tenant_Id, positionId])
  @@index([tenant_Id, managerId])
  @@index([tenant_Id, workShiftId])
  @@index([tenant_Id, attendanceMethod])
  @@index([tenant_Id, customFieldSchemaVersion])
}

model OrgUnit {
  id                String      @id @default(cuid())
  tenant_Id         String
  code              String?
  name              String
  type              OrgUnitType
  parentId          String?
  managerEmployeeId String?
  description       String?
  orderNo           Int?        @default(0)
  status            GenericStatus @default(ACTIVE)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  parent   OrgUnit?  @relation("OrgUnitHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children OrgUnit[] @relation("OrgUnitHierarchy")

  @@unique([tenant_Id, code])
  @@index([tenant_Id])
  @@index([tenant_Id, type])
  @@index([tenant_Id, parentId])
}

model Department {
  id             String   @id @default(cuid())
  tenant_Id      String
  code           String?
  name           String
  managerEmployeeId String?
  description    String?
  status         GenericStatus @default(ACTIVE)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenant_Id, code])
  @@index([tenant_Id])
  @@index([tenant_Id, name])
}

model Position {
  id             String   @id @default(cuid())
  tenant_Id      String
  code           String?
  title          String
  departmentId   String?
  level          String?
  description    String?
  status         GenericStatus @default(ACTIVE)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenant_Id, code])
  @@index([tenant_Id])
  @@index([tenant_Id, departmentId])
}

model PositionPermissionRule {
  id         String           @id @default(cuid())
  tenant_Id  String
  positionId String
  moduleKey  String
  action     PermissionAction
  effect     PermissionEffect
  createdBy  String?
  reason     String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([tenant_Id, positionId, moduleKey, action])
  @@index([tenant_Id])
  @@index([tenant_Id, positionId])
  @@index([tenant_Id, moduleKey, action])
}

model UserPermissionOverride {
  id         String           @id @default(cuid())
  tenant_Id  String
  userId     String
  moduleKey  String
  action     PermissionAction
  effect     PermissionEffect
  createdBy  String?
  reason     String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([tenant_Id, userId, moduleKey, action])
  @@index([tenant_Id])
  @@index([tenant_Id, userId])
  @@index([tenant_Id, moduleKey, action])
}

model IamActionGrant {
  id          String           @id @default(cuid())
  tenant_Id   String
  subjectType IamSubjectType
  subjectId   String
  moduleKey   String
  action      PermissionAction
  effect      PermissionEffect
  priority    Int              @default(100)
  createdBy   String?
  updatedBy   String?
  reason      String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([tenant_Id])
  @@index([tenant_Id, subjectType, subjectId, moduleKey, action])
  @@index([tenant_Id, moduleKey, action])
  @@map("iam_action_grants")
}

model IamCapabilityGrant {
  id            String           @id @default(cuid())
  tenant_Id     String
  subjectType   IamSubjectType
  subjectId     String
  capabilityKey String
  effect        PermissionEffect
  priority      Int              @default(100)
  createdBy     String?
  updatedBy     String?
  reason        String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([tenant_Id])
  @@index([tenant_Id, subjectType, subjectId, capabilityKey])
  @@map("iam_capability_grants")
}

model IamUserScopeOverride {
  id            String       @id @default(cuid())
  tenant_Id     String
  userId        String
  scopeMode     IamScopeMode
  rootOrgUnitId String?
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  reason        String?
  createdBy     String?
  updatedBy     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([tenant_Id, userId])
  @@index([tenant_Id, scopeMode])
  @@index([tenant_Id, rootOrgUnitId])
  @@map("iam_user_scope_override")
}

model IamPermissionCeiling {
  id            String            @id @default(cuid())
  tenant_Id     String
  actorUserId   String
  moduleKey     String?
  action        PermissionAction?
  capabilityKey String?
  effect        PermissionEffect  @default(ALLOW)
  priority      Int               @default(100)
  reason        String?
  createdBy     String?
  updatedBy     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([tenant_Id])
  @@index([tenant_Id, actorUserId])
  @@index([tenant_Id, actorUserId, moduleKey, action])
  @@index([tenant_Id, actorUserId, capabilityKey])
  @@map("iam_permission_ceiling")
}

model IamResolvedScopeMember {
  id           String   @id @default(cuid())
  tenant_Id    String
  userId       String
  scopeVersion Int      @default(1)
  employeeIds  String[] @default([])
  orgUnitIds   String[] @default([])
  computedAt   DateTime @default(now())
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenant_Id, userId])
  @@index([tenant_Id, expiresAt])
  @@map("iam_resolved_scope_members")
}

model IamRecordAccessGrant {
  id          String             @id @default(cuid())
  tenant_Id   String
  actorUserId String
  recordType  String
  recordId    String
  grantReason IamGrantReason     @default(WORKFLOW_ASSIGNMENT)
  actions     PermissionAction[] @default([])
  expiresAt   DateTime?
  sourceRef   String?
  reason      String?
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([tenant_Id])
  @@index([tenant_Id, actorUserId, recordType, recordId])
  @@index([tenant_Id, recordType, recordId])
  @@index([tenant_Id, expiresAt])
  @@map("iam_record_access_grants")
}

model WorkShift {
  id                      String   @id @default(cuid())
  tenant_Id               String
  code                    String?
  name                    String
  startTime               String
  endTime                 String
  breakMinutes            Int      @default(60)
  overtimeThresholdMinutes Int     @default(30)
  status                  GenericStatus @default(ACTIVE)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([tenant_Id, code])
  @@index([tenant_Id])
}

model LeavePolicy {
  id                    String   @id @default(cuid())
  tenant_Id             String
  code                  String?
  name                  String
  leaveType             String
  isPaid                Boolean  @default(true)
  annualQuotaDays       Decimal? @db.Decimal(6, 2)
  carryOverLimitDays    Decimal? @db.Decimal(6, 2)
  maxConsecutiveDays    Int?
  requiresAttachment    Boolean  @default(false)
  status                GenericStatus @default(ACTIVE)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([tenant_Id, code])
  @@index([tenant_Id])
  @@index([tenant_Id, leaveType])
}

model Customer {
  id            String   @id @default(cuid())
  tenant_Id     String
  code          String?
  fullName      String
  email         String?
  emailNormalized String?
  phone         String?
  phoneNormalized String?
  tags          String[] @default([])
  customerStage String? @default("MOI")
  ownerStaffId  String?
  consentStatus String?
  segment       String?
  source        String?
  needsSummary  String?
  customFieldSchemaVersion Int?
  totalOrders   Int      @default(0)
  totalSpent    Decimal? @db.Decimal(18, 2)
  lastOrderAt   DateTime?
  lastContactAt DateTime?
  status        CustomerCareStatus @default(MOI_CHUA_TU_VAN)
  zaloNickType  CustomerZaloNickType @default(CHUA_KIEM_TRA)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders        Order[]
  interactions  CustomerInteraction[]
  serviceContracts ServiceContract[]
  socialIdentities CustomerSocialIdentity[]
  ownedVehicles Vehicle[] @relation("CustomerOwnedVehicles")
  telecomBeneficiaryLines TelecomServiceLine[] @relation("TelecomBeneficiaryCustomer")
  inboundPolicyDocuments InboundPolicyDocument[]
  externalOrderIngests ExternalOrderIngest[]
  zaloCampaignRecipients ZaloCampaignRecipient[]
  zaloCampaignAttempts ZaloCampaignMessageAttempt[]
  paymentRequests PaymentRequest[]
  primaryMergeLogs CustomerMergeLog[] @relation("primaryCustomer")
  mergedFromLogs   CustomerMergeLog[] @relation("mergedCustomer")
  conversationThreads ConversationThread[]

  @@unique([tenant_Id, code])
  @@unique([tenant_Id, phoneNormalized])
  @@unique([tenant_Id, emailNormalized])
  @@index([tenant_Id])
  @@index([tenant_Id, phone])
  @@index([tenant_Id, email])
  @@index([tenant_Id, status])
  @@index([tenant_Id, zaloNickType])
  @@index([tenant_Id, customFieldSchemaVersion])
}

model CustomerInteraction {
  id              String   @id @default(cuid())
  tenant_Id       String
  customerId      String
  interactionType String
  channel         String
  content         String
  resultTag       String?
  staffName       String?
  staffCode       String?
  interactionAt   DateTime @default(now())
  nextActionAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer        Customer @relation(fields: [customerId], references: [id])

  @@index([tenant_Id])
  @@index([tenant_Id, customerId])
  @@index([tenant_Id, interactionAt])
}

model PaymentRequest {
  id            String   @id @default(cuid())
  tenant_Id     String
  customerId    String?
  invoiceId     String?
  invoiceNo     String?
  orderNo       String?
  channel       String
  recipient     String?
  qrCodeUrl     String?
  amount        Decimal? @db.Decimal(18, 2)
  status        String   @default("DA_GUI")
  sentAt        DateTime?
  paidAt        DateTime?
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer      Customer? @relation(fields: [customerId], references: [id])

  @@index([tenant_Id])
  @@index([tenant_Id, customerId])
  @@index([tenant_Id, invoiceNo])
  @@index([tenant_Id, status])
}

model PaymentIntent {
  id             String            @id @default(cuid())
  tenant_Id      String
  orderId        String
  intentCode     String
  amountLocked   Decimal           @db.Decimal(18, 2)
  paidAmount     Decimal           @default(0) @db.Decimal(18, 2)
  remainingAmount Decimal          @default(0) @db.Decimal(18, 2)
  currency       String            @default("VND")
  qrPayload      String?
  paymentLink    String?
  qrActive       Boolean           @default(true)
  status         PaymentIntentStatus @default(UNPAID)
  paidAt         DateTime?
  lockedAt       DateTime          @default(now())
  expiresAt      DateTime?
  metadataJson   Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  order          Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transactions   PaymentTransaction[]
  overrides      PaymentOverrideLog[]

  @@unique([tenant_Id, orderId])
  @@unique([tenant_Id, intentCode])
  @@index([tenant_Id])
  @@index([tenant_Id, status])
  @@index([tenant_Id, createdAt])
}

model PaymentTransaction {
  id             String                   @id @default(cuid())
  tenant_Id      String
  intentId       String
  transactionRef String
  bankTxnAt      DateTime?
  amount         Decimal                  @db.Decimal(18, 2)
  currency       String                   @default("VND")
  rawPayloadJson Json?
  dedupeHash     String
  status         PaymentTransactionStatus @default(RECEIVED)
  note           String?
  source         String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  intent         PaymentIntent            @relation(fields: [intentId], references: [id], onDelete: Cascade)

  @@unique([tenant_Id, dedupeHash])
  @@index([tenant_Id])
  @@index([tenant_Id, intentId, createdAt])
  @@index([tenant_Id, transactionRef])
}

model PaymentOverrideLog {
  id           String        @id @default(cuid())
  tenant_Id    String
  intentId     String
  overrideBy   String
  overrideRole String?
  reason       String
  reference    String?
  amount       Decimal       @db.Decimal(18, 2)
  note         String?
  metadataJson Json?
  createdAt    DateTime      @default(now())

  intent       PaymentIntent @relation(fields: [intentId], references: [id], onDelete: Cascade)

  @@index([tenant_Id])
  @@index([tenant_Id, intentId, createdAt])
}

model CustomerMergeLog {
  id                String   @id @default(cuid())
  tenant_Id         String
  primaryCustomerId String
  mergedCustomerId  String
  mergedBy          String?
  note              String?
  mergedAt          DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  primaryCustomer   Customer @relation("primaryCustomer", fields: [primaryCustomerId], references: [id])
  mergedCustomer    Customer @relation("mergedCustomer", fields: [mergedCustomerId], references: [id])

  @@index([tenant_Id])
  @@index([tenant_Id, primaryCustomerId])
  @@index([tenant_Id, mergedCustomerId])
}

model Product {
  id            String   @id @default(cuid())
  tenant_Id     String
  sku           String?
  name          String
  productType   String
  categoryPath  String?
  attributesJson Json?
  variantOfProductId String?
  pricePolicyCode String?
  customFieldSchemaVersion Int?
  unitPrice     Decimal  @db.Decimal(18, 2)
  status        GenericStatus @default(ACTIVE)
  archivedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  variantOf     Product? @relation("ProductVariants", fields: [variantOfProductId], references: [id], onDelete: SetNull)
  variants      Product[] @relation("ProductVariants")
  orderItems    OrderItem[]

  @@unique([tenant_Id, sku])
  @@index([tenant_Id])
  @@index([tenant_Id, variantOfProductId])
  @@index([tenant_Id, categoryPath])
  @@index([tenant_Id, pricePolicyCode])
  @@index([tenant_Id, customFieldSchemaVersion])
}

model Order {
  id            String   @id @default(cuid())
  tenant_Id     String
  orderNo       String?
  orderGroup    CheckoutOrderGroup?
  checkoutStatus CheckoutOrderStatus?
  customerId    String?
  customerName  String?
  employeeId    String?
  customFieldSchemaVersion Int?
  totalAmount   Decimal? @db.Decimal(18, 2)
  status        GenericStatus @default(PENDING)
  commercialLockedAt DateTime?
  commercialSnapshotJson Json?
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer      Customer? @relation(fields: [customerId], references: [id])
  items         OrderItem[]
  invoices      Invoice[]
  paymentIntents PaymentIntent[]
  serviceContracts ServiceContract[]
  externalOrderIngests ExternalOrderIngest[]

  @@unique([tenant_Id, orderNo])
  @@index([tenant_Id])
  @@index([tenant_Id, orderGroup])
  @@index([tenant_Id, checkoutStatus])
  @@index([tenant_Id, createdAt])
  @@index([tenant_Id, employeeId])
