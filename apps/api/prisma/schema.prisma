  attempts    ZaloCampaignMessageAttempt[]

  @@unique([tenant_Id, code])
  @@index([tenant_Id])
  @@index([tenant_Id, status])
  @@index([tenant_Id, createdAt])
  @@map("zalo_campaigns")
}

