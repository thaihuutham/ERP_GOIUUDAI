  targetAccount ZaloAccount?  @relation("ZaloCampaignRecipientTargetAccount", fields: [targetAccountId], references: [id], onDelete: SetNull)
  attempts      ZaloCampaignMessageAttempt[]

  @@unique([tenant_Id, campaignId, customerId])
  @@index([tenant_Id])
  @@index([tenant_Id, campaignId, status, targetAccountId, createdAt])
  @@index([tenant_Id, campaignId, targetAccountId, status])
