  evaluationId  String
  severity      String
  ruleName      String
  evidence      String?
  explanation   String?
  suggestion    String?
  confidence    Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  evaluation ConversationEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([tenant_Id])
  @@index([tenant_Id, evaluationId])
}
