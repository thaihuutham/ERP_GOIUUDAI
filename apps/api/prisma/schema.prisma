  delayMaxSeconds             Int                         @default(300)
  maxConsecutiveErrors        Int                         @default(3)
  maxRecipients               Int?
  selectionPolicy             ZaloCampaignSelectionPolicy @default(PRIORITIZE_RECENT_INTERACTION)
  allowedVariableKeys         String[]                    @default([])
  recipientFilterJson         Json?
  createdBy                   String?
  startedAt                   DateTime?
  pausedAt                    DateTime?
  completedAt                 DateTime?
  canceledAt                  DateTime?
