  @@unique([tenant_Id, threadId, externalMessageId])
  @@index([tenant_Id])
  @@index([tenant_Id, threadId, sentAt])
  @@index([tenant_Id, threadId, origin, sentAt])
}

model ConversationEvaluationJob {
  id                    String   @id @default(cuid())
  tenant_Id             String
  name                  String
  description           String?
  jobType               String   @default("QC_ANALYSIS")
  isActive              Boolean  @default(true)
  intervalMinutes       Int      @default(120)
  nextRunAt             DateTime?
  lastRunAt             DateTime?
  lastRunStatus         String?
  lookbackHours         Int      @default(24)
  maxConversationsPerRun Int     @default(30)
  batchSize             Int      @default(5)
  aiProvider            String   @default("OPENAI_COMPATIBLE")
  aiModel               String?
  channelFilterJson     Json?
  rulesContent          String?
  skipConditions        String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  runs ConversationEvaluationRun[]

  @@index([tenant_Id])
  @@index([tenant_Id, isActive, nextRunAt])
}

model ConversationEvaluationRun {
  id             String   @id @default(cuid())
  tenant_Id      String
  jobId          String
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  status         String   @default("RUNNING")
  summaryJson    Json?
  errorMessage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  job         ConversationEvaluationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  evaluations ConversationEvaluation[]

  @@index([tenant_Id])
  @@index([tenant_Id, jobId, startedAt])
}

model ConversationEvaluation {
  id            String   @id @default(cuid())
  tenant_Id     String
  threadId      String
  runId         String?
  verdict       ConversationEvaluationVerdict @default(ERROR)
  score         Int?
  review        String?
  summary       String?
  provider      String?
  model         String?
  rawResponseJson Json?
  inputTokens   Int?
  outputTokens  Int?
  costUsd       Decimal? @db.Decimal(12, 6)
  evaluatedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  thread     ConversationThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  run        ConversationEvaluationRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
  violations ConversationViolation[]

  @@index([tenant_Id])
  @@index([tenant_Id, threadId, evaluatedAt])
  @@index([tenant_Id, runId])
}

