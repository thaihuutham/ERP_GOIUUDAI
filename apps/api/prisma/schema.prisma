model ZaloCampaign {
  id                          String                      @id @default(cuid())
  tenant_Id                   String
  code                        String?
  name                        String
  status                      ZaloCampaignStatus          @default(DRAFT)
  timezone                    String                      @default("Asia/Ho_Chi_Minh")
