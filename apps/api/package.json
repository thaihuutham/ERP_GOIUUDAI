{
  "name": "@erp/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm --experimental-specifier-resolution=node src/main.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths --resolve-full-extension .js",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "seed:demo": "npx ts-node --esm scripts/seed-demo.ts",
    "token:dev": "npx ts-node --esm scripts/issue-token.ts",
    "search:reindex": "npx ts-node --esm scripts/search-reindex.ts",
    "benchmark:workflows:inbox": "npx ts-node --esm scripts/benchmark-workflows-inbox.ts",
    "smoke:workflows:lifecycle": "npx ts-node --esm scripts/smoke-workflow-definition-lifecycle.ts",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:migrate:status": "prisma migrate status --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.910.0",
    "@erp/shared": "file:../../packages/shared",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@prisma/client": "^6.19.2",
    "prisma": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "jsonwebtoken": "^9.0.2",
    "meilisearch": "^0.56.0",
    "nestjs-cls": "^6.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zca-js": "^2.1.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
